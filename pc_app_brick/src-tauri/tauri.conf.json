{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BRICK",
  "version": "0.1.0",
  "identifier": "com.brick.robotics",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BRICK - Robotics Within Reach",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"]
  }
}
